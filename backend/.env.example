# =============================================
# LegalAssist Chatbot — Environment Variables
# Copy this to .env and fill in your values
# =============================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Admin Authentication (set a strong password!)
ADMIN_PASSWORD=your-secure-admin-password-here
JWT_SECRET=your-random-jwt-secret-at-least-32-chars-here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://legalassist.co.uk,http://localhost:3000

# Database (auto-created in project root)
DATABASE_URL=sqlite:///./legalassist.db

# ChromaDB persistence directory
CHROMA_DB_PATH=./chroma_db

# Website to scrape
SITE_URL=https://legalassist.co.uk
SITE_SITEMAP_URL=https://legalassist.co.uk/page-sitemap.xml

# App environment
APP_ENV=production
