# =============================================
# LegalAssist Chatbot — Environment Variables
# Copy this to .env and fill in your values
# =============================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Admin Authentication (set a strong password!)
ADMIN_PASSWORD=your-secure-admin-password-here
JWT_SECRET=your-random-jwt-secret-at-least-32-chars-here

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://legalassistglobal.com,http://localhost:3000

# ── Neon PostgreSQL (Production) ────────────────────────────────────
# Get these from your Neon dashboard → Project → Connection Details
DB_HOST=ep-long-recipe-ab0ct4dm.eu-west-2.aws.neon.tech
DB_USER=neondb_owner
DB_PASSWORD=your-neon-db-password-here
DB_PORT=5432
DB_NAME=neondb

# ── Local Development fallback ───────────────────────────────────────
# Only used if DB_HOST is not set (e.g. local SQLite for quick testing)
DATABASE_URL=sqlite:///./legalassist.db

# Website to scrape
SITE_URL=https://legalassistglobal.com
SITE_SITEMAP_URL=https://legalassistglobal.com/page-sitemap.xml

# App environment
APP_ENV=production
